# SWARMICA v1.0.0 Environment Variables
# Variational and Continuum Mechanics Framework for Collective Swarm Stability

# ============= Swarm Configuration =============
SWARMICA_N_AGENTS=500
SWARMICA_MODALITY=aerial
SWARMICA_N_BASIS=64
SWARMICA_SOS_DEGREE=4

# ============= Control Parameters =============
SWARMICA_K_COUPLING=3.0
SWARMICA_MU_DISSIPATION=0.02
SWARMICA_DT=0.001
SWARMICA_TARGET_CONFIG=diamond_V

# ============= Phase Synchronization (Kuramoto) =============
SWARMICA_K_CRITICAL=2.0
SWARMICA_ORDER_PARAMETER_THRESHOLD=0.95

# ============= Stability Certification =============
SWARMICA_EIGENVALUE_TOLERANCE=1e-6
SWARMICA_SIGMA_MIN=0.01

# ============= Hardware Deployment =============
SWARMICA_PRECISION=FP32
SWARMICA_FPGA_TARGET=versal

# ============= Logging =============
SWARMICA_LOG_LEVEL=INFO
SWARMICA_SAVE_RESULTS=true
SWARMICA_RESULTS_DIR=./results

# ============= API Keys (Optional) =============
# GITHUB_TOKEN=your_token_here
